# ============================================
# ZEGO Configuration (Required)
# Get from: https://console.zego.im/
# ============================================

# ZEGO Application ID (number)
APP_ID=your_app_id

# Server Secret (32-char string)
# WARNING: Keep this secret! Never expose to client!
SERVER_SECRET=your_server_secret

# Token validity period (seconds)
TOKEN_EXPIRE_SECONDS=3600

# LLM Configuration (ByteDance/Volcengine)
LLM_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
LLM_API_KEY=your_llm_api_key
LLM_MODEL=doubao-1-5-pro-32k-250115
LLM_SYSTEM_PROMPT=You are a friendly AI avatar assistant. Answer concisely.

# TTS Configuration (ByteDance Volcano TTS)
TTS_APP_ID=your_tts_app_id
TTS_TOKEN=your_tts_token
TTS_VOICE_TYPE=zh_female_wanwanxiaohe_moon_bigtts
